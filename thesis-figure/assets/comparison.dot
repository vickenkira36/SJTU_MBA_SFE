// Template: Side-by-Side Comparison Diagram
// Usage: As-Is vs To-Be, before/after, two-option comparison
// Customize: Replace labels, adjust WIDTH, add rows

digraph G {
    rankdir=TB;
    dpi=300;
    bgcolor="white";
    fontname="Noto Sans CJK SC";
    nodesep=0.8;
    ranksep=0.5;

    node [fontname="Noto Sans CJK SC", shape=none, margin="0"];
    edge [color="black", penwidth=1.8, arrowsize=1.0];

    // --- Top title ---
    title [label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="8"
               BGCOLOR="black">
            <TR><TD ALIGN="CENTER" WIDTH="400">
                <FONT COLOR="white" POINT-SIZE="13"><B>对比分析标题</B></FONT>
            </TD></TR>
        </TABLE>
    >];

    // --- Left panel (As-Is / Before) ---
    left [label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
            <TR><TD BGCOLOR="black" CELLPADDING="6" ALIGN="CENTER">
                <FONT COLOR="white" POINT-SIZE="11"><B>As-Is（现状）</B></FONT>
            </TD></TR>
            <TR><TD CELLPADDING="8" ALIGN="CENTER">
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="4">
                    <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• 特征一描述</FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• 特征二描述</FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• 特征三描述</FONT></TD></TR>
                </TABLE>
            </TD></TR>
        </TABLE>
    >];

    // --- Right panel (To-Be / After) ---
    right [label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
            <TR><TD BGCOLOR="black" CELLPADDING="6" ALIGN="CENTER">
                <FONT COLOR="white" POINT-SIZE="11"><B>To-Be（优化后）</B></FONT>
            </TD></TR>
            <TR><TD CELLPADDING="8" ALIGN="CENTER">
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="4">
                    <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• 改进一描述</FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• 改进二描述</FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• 改进三描述</FONT></TD></TR>
                </TABLE>
            </TD></TR>
        </TABLE>
    >];

    // --- Arrow between panels ---
    arrow [label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
            <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10"><B>→</B></FONT></TD></TR>
            <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9">优化</FONT></TD></TR>
        </TABLE>
    >];

    // --- Bottom result ---
    result [label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="8"
               BGCOLOR="#f0f0f0">
            <TR><TD ALIGN="CENTER" WIDTH="400"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
                <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10"><B>对比结论</B></FONT></TD></TR>
                <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">关键指标提升 XX%</FONT></TD></TR>
            </TABLE></TD></TR>
        </TABLE>
    >];

    // --- Caption ---
    caption [label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="4">
            <TR><TD ALIGN="CENTER"><B><FONT POINT-SIZE="11">图 X-Y    对比分析标题</FONT></B></TD></TR>
            <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">Figure X-Y  Comparison Title</FONT></TD></TR>
        </TABLE>
    >];

    // --- Layout ---
    { rank=same; left; arrow; right; }

    title -> left [style=invis];
    title -> right [style=invis];
    left -> arrow [style=invis];
    arrow -> right [style=invis];
    left -> result [style=invis];
    right -> result [style=invis];
    result -> caption [style=invis];
}
